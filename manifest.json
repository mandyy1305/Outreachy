{
  "manifest_version": 3,
  "name": "RemoteStar Outreach Assistant",
  "version": "0.2.0",
  "description": "Find, research, and reach the right people to pitch RemoteStar — from the LinkedIn page you're viewing.",
  "key": "",
  "permissions": ["storage", "activeTab", "scripting", "sidePanel", "identity", "identity.email"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://www.signalhire.com/*",
    "https://gmail.googleapis.com/*",
    "https://www.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "419145443553-idab3a2r4357afjt7p0vvsdaatg898jj.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.send",
      "https://www.googleapis.com/auth/userinfo.email"
    ]
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "RemoteStar Outreach"
  },
  "side_panel": {
    "default_path": "src/sidepanel/sidepanel.html"
  },
  "options_page": "src/options/options.html",
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
